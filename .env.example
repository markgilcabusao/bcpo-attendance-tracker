# Supabase Configuration
# Copy this file to .env and fill in your Supabase credentials

# Your Supabase project URL
# Get this from your Supabase dashboard: Project Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key
# Get this from your Supabase dashboard: Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here
